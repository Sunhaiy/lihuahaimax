# ============================================================
# 数据库 (PostgreSQL)
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/lihuahaimax"
# 或拆分写法（pg 连接池优先使用 DATABASE_URL，若无则读取以下字段）
PGHOST="localhost"
PGPORT="5432"
PGDATABASE="lihuahaimax"
PGUSER="your_db_user"
PGPASSWORD="your_db_password"

# ============================================================
# NextAuth.js (Auth.js v5)
# ============================================================
# 在生产环境替换为真实随机字符串，例如：openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-replace-in-production"
# 管理员账号（首次可用环境变量兜底，后台保存后会写入数据库）
ADMIN_EMAIL="admin@lihuahai.com"
ADMIN_PASSWORD="your-secure-admin-password"

# ============================================================
# 应用基础 URL
# ============================================================
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================================
# 媒体文件存储
# ============================================================
# 上传文件保存到服务器本地的绝对路径
UPLOAD_DIR="./public/uploads"
# 对外访问时的 URL 前缀
UPLOAD_PUBLIC_PATH="/uploads"

# ============================================================
# DeepSeek 自动写文
# ============================================================
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ============================================================
# 定时任务 (Cron)
# ============================================================
# 小米手环数据接入预留（未来对接第三方 API 或本地同步脚本）
MI_BAND_SYNC_CRON="0 * * * *"
MI_BAND_API_TOKEN=""
